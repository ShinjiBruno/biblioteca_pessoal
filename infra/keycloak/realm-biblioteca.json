{
  "realm": "biblioteca-realm",
  "enabled": true,
  "displayName": "Biblioteca Realm",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "verifyEmail": false,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Usuario comum"
      },
      {
        "name": "admin",
        "description": "Administrador"
      }
    ]
  },
  "clients": [
    {
      "clientId": "client_dev",
      "name": "Biblioteca Frontend",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:4200/*"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "Biblioteca",
      "email": "admin@biblioteca.local",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "user"
      ]
    }
  ]
}
